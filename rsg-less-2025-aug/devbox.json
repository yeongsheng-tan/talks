{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "nodejs@25",
    "corepack@latest"
  ],
  "env": {
    "DEVBOX_COREPACK_ENABLED": "1"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox for rsg-less-2025-aug!' > /dev/null",
      ". ./set-env.sh"
    ],
    "scripts": {
      "slide-show": [
        "pnpm run dev"
      ]
    }
  }
}
